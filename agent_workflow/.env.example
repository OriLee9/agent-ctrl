# Agent Workflow Framework — 环境配置
# 复制为 .env 并修改实际值:  cp .env.example .env

# ── LLM API ──────────────────────────────────────────────
# DeepSeek API Key（必需，用于 Agent 调用 LLM）
DEEPSEEK_API_KEY=sk-85ead2184a654fc38c77ed4d31fc4289
# DeepSeek 模型类型: v4-pro（默认） | v4-flash
#   v4-pro   → 高性能，适合复杂任务
#   v4-flash → 快速响应，适合简单任务
DEEPSEEK_API_TYPE=v4-flash
# 可选：直接指定模型 ID（优先级高于 DEEPSEEK_API_TYPE）
# DEEPSEEK_MODEL=deepseek-v4-pro
# 可选：自定义 API Base URL
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── API Server ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5000
# 跨域设置（开发模式建议开启）
API_CORS=true

# ── Frontend ─────────────────────────────────────────────
FRONTEND_PORT=5173

# ── 数据持久化 ───────────────────────────────────────────
# SQLite 数据库路径
DB_PATH=/tmp/agent_workflow/context_hub.db
# Checkpoint 保存目录
CHECKPOINT_DIR=/tmp/agent_workflow/checkpoints
# Agent 步级 checkpoint 目录
AGENT_CHECKPOINT_DIR=/tmp/agent_checkpoints

# 产物输出目录（Agent save_file 工具保存位置，前端通过 /api/artifact 访问）
ARTIFACTS_DIR=/tmp/agent_workflow/artifacts

# ── 框架行为 ─────────────────────────────────────────────
# 默认 Agent 配置
DEFAULT_MAX_ITERATIONS=15
DEFAULT_TEMPERATURE=0.7
# Token 预算（0=无限制）
DEFAULT_BUDGET_TOKENS=0
# 是否启用步级 checkpoint
CHECKPOINT_ENABLED=false
# 演示模式（启动模拟 Agent 运行）
DEMO_MODE=false
